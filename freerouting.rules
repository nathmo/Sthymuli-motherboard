
(rules PCB freerouting.dsn
  (snap_angle 
    fortyfive_degree
  )
  (autoroute_settings
    (fanout off)
    (autoroute on)
    (postroute off)
    (vias on)
    (via_costs 50)
    (plane_via_costs 5)
    (start_ripup_costs 100)
    (start_pass_no 1)
    (layer_rule F.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.8)
      (against_preferred_direction_trace_costs 5.6)
    )
    (layer_rule In1.Cu
      (active on)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 2.9)
    )
    (layer_rule In2.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 4.8)
    )
    (layer_rule B.Cu
      (active on)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 1.8)
      (against_preferred_direction_trace_costs 3.7)
    )
  )
  (rule
    (width 200.0)
    (clearance 200.0)
    (clearance -0.1 (type smd_to_turn_gap))
    (clearance 50.0 (type smd))
    (clearance 200.0 (type "kicad_default"))
  )
  (padstack "Via[0-3]_600:300_um"
    (shape
      (circle F.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle In1.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle In2.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 600.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-3]_600:300_um" "Via[0-3]_600:300_um" default
  )
  (via 
    "Via[0-3]_600:300_um-kicad_default" "Via[0-3]_600:300_um" "kicad_default"
  )
  (via_rule
    default "Via[0-3]_600:300_um"
  )
  (via_rule
    "kicad_default" "Via[0-3]_600:300_um-kicad_default"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 200.0)
    )
    (circuit 
      (use_layer F.Cu In1.Cu In2.Cu B.Cu)
    )
  )
  (class "kicad_default"
    +5V GND "Net-(Q7-D)" "Net-(U5-SRP)" "Net-(U3-VC1)" "Net-(U3-VC2)" "BOOT_MODE" "Net-(C83-Pad1)"
    "Net-(MKTD4015BPN1--)" "Net-(U11-+)" "Net-(U9-Vcc)" +3V3 "Net-(Q1-S)" "Net-(U6-FB)" "Net-(MKTD4015BPN1-+)" GNDA
    "Net-(Q7-G)" "Net-(Q6-D)" "IR_analog" "Net-(U11--)" "Net-(D2-DOUT)" "Net-(D1-DOUT)" "Net-(ES1-CE)" "Net-(Q3-G)"
    "Net-(Q3-S)" "Net-(Q3-D)" "Net-(D4-DOUT)" "Net-(D3-DOUT)" "Net-(U3-SRP)" "Net-(U3-SRN)" "Net-(U5-ACP)" "Net-(C36-Pad1)"
    "Net-(U3-BAT)" "Net-(U6-SW)" "Net-(U3-VC0)" "Net-(U3-TS)" "Net-(U3-DSG)" "Net-(U3-CHG)" SCL SDA
    "BMS_ALERT" "unconnected-(U3-REGOUT-Pad15)" "Net-(U3-REGSRC)" "Net-(U3-VC5)" "Net-(U3-VC4A)" "Net-(U5-ACN)" "Net-(U1-3V3)" "Net-(D6-DOUT)"
    "Net-(D5-DOUT)" "Net-(D1-VDD)" RST "IR_receiver" "Net-(D30-K)" "PWR_ON" "Net-(D31-K)" "Net-(Q8-D)"
    "Net-(U5-COMP2)" "Net-(R60-Pad1)" /D+ "Net-(ES1-VMID)" "Net-(U5-VBUS)" "CHRG_OK" OTG "Net-(U5-ILIM_HIZ)"
    "Net-(U5-VDDA)" "Net-(U5-IADPT)" "Net-(U5-IBAT)" "Net-(U5-PSYS)" "unconnected-(U5-~{PROCHOT}-Pad11)" "unconnected-(U5-CMPIN-Pad14)" "unconnected-(U5-CMPOUT-Pad15)" "Net-(U5-COMP1)"
    "Net-(U5-CELL_BATPRESZ)" "Net-(U5-SRN)" "Net-(Q5-D)" "Net-(Q6-G)" "Net-(U5-BTST2)" "Net-(Q5-G)" "Net-(U5-REGN)" "Net-(Q4-G)"
    "Net-(U5-BTST1)" "unconnected-(U5-thermal_pad-Pad33)" VBUS "Net-(J1-CC1)" "/D-" "unconnected-(J1-SBU1-PadA8)" "Net-(J1-CC2)" "unconnected-(J1-SBU2-PadB8)"
    "Net-(ES1-ADC{slash}REF)" "Net-(C44-Pad1)" "Net-(ES1-CCLK)" "Net-(Q1-G)" "Net-(C73-Pad2)" "Net-(U2-EN)" "Net-(ES1-SPKVDD)" "Net-(ES1-SPKLP)"
    "Net-(ES1-SPKLN)" "Net-(D7-DOUT)" "Net-(ES1-DAC{slash}REF)" "unconnected-(U7-NC-Pad11)" "unconnected-(U7-NC-Pad14)" "GPIO_INTB" "GPIO_INTA" "Net-(J3-Pin_1)"
    "Net-(J3-Pin_2)" "Net-(J3-Pin_3)" "IR_S0" "IR_S1" "IR_S2" "Net-(U4-FB)" "IR_MODULATION" "Net-(Q9-D)"
    "Net-(Q2-G)" "Net-(U4-SW)" "unconnected-(U4-EN-Pad5)" "Net-(U4-BST)" "Net-(BT4-+)" "Net-(U10-A)" "Net-(ES1-CDATA)" "unconnected-(U1-IO5-Pad5)"
    "EXT_GPIO_1" "I2S_DOUT" "I2S_MCLK" "ACC_B_INT1" "ACC_A_INT1" "EXT_GPIO_2" "unconnected-(U1-IO46-Pad16)" "I2S_SCLK"
    "I2S_LCLK" "I2S_DSIN" "unconnected-(U1-IO21-Pad23)" "unconnected-(U1-IO45-Pad26)" "unconnected-(U1-IO35-Pad28)" "unconnected-(U1-IO36-Pad29)" "unconnected-(U1-IO37-Pad30)" "Net-(J2-Pin_4)"
    "Net-(J2-Pin_5)" "Net-(J2-Pin_6)" "Net-(J2-Pin_7)" "Net-(J2-Pin_8)" "Net-(J2-Pin_3)" "Net-(J2-Pin_2)" "/MIC_N" "Net-(C39-Pad1)"
    "/MIC_P" "unconnected-(U2-NC-Pad4)" "Net-(Q1-D)" /MICBIAS "unconnected-(ES1-PLLout{slash}GPIO2-Pad4)" "unconnected-(ES1-MONOUT-Pad15)" "unconnected-(ES1-RIN1-Pad24)" "unconnected-(ES1-LIN1{slash}DMIC_SDA-Pad25)"
    "unconnected-(ES1-DMICLK{slash}GPIO1-Pad26)" "Net-(R61-Pad1)" "Net-(U6-BST)" "unconnected-(U14-INT2-Pad9)" "unconnected-(U14-NC-Pad10)" "unconnected-(U14-NC-Pad11)" "NORTH_BAT-" "WEST_BAT+"
    "WS2812_DIN" "EAST_BAT-" "NORTH_IR_TRA_HORI" "NORTH_IR_TRA_VERT" "SOUTH_BAT+" "EAST_BAT+" "NORTH_IR_REC_HORI" "NORTH_IR_REC_VERT"
    "NORTH_btn_B" "NORTH_btn_A" "SOUTH_btn_A" "WEST_btn_B" "EAST_btn_A" "EAST_btn_B" "WEST_btn_A" "SOUTH_btn_B"
    "EAST_IR_REC_HORI" "SOUTH_IR_REC_VERT" "SOUTH_IR_REC_HORI" "WEST_IR_REC_VERT" "EAST_IR_REC_VERT" "WEST_IR_REC_HORI" "SOUTH_IR_TRA_VERT" "EAST_IR_TRA_HORI"
    "WEST_IR_TRA_VERT" "SOUTH_IR_TRA_HORI" "EAST_IR_TRA_VERT" "WEST_IR_TRA_HORI" "Net-(J12-Pin_8)" "unconnected-(J8-Pin_16-Pad16)" "unconnected-(J11-Pin_9-Pad9)" "Net-(J11-Pin_8)"
    "unconnected-(J11-Pin_16-Pad16)"
    (clearance_class "kicad_default")
    (via_rule "kicad_default")
    (rule
      (width 200.0)
    )
    (circuit 
      (use_layer F.Cu In1.Cu In2.Cu B.Cu)
    )
  )
)